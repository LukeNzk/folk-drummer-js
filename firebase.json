{
  "hosting": {
    "site": "folk-drum",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.json",
        "headers": [
          { "key": "Content-Type", "value": "application/json; charset=utf-8" }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "/**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }
        ]
      },
      {
        "source": "/**/*.@(png|jpg|jpeg|gif|svg|webp|ogg)",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=7776000" }
        ]
      },
      {
        "source": "/service-worker.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ],
    "rewrites": [{
      "source": "/:file",
        "destination": "/public/:file"
      },
      { "source": "**", "destination": "/index_new.html" }
    ]
  }
}
